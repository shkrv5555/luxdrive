# ════════════════════════════════════════════════════════════
# LuxDrive Frontend — Mühit dəyişənləri
# Bu faylı `.env` olaraq kopyalayın və dəyərləri tənzimləyin
# ════════════════════════════════════════════════════════════

# Backend API URL
# Vite proxy istifadə edirsinizsə (vite.config.js-də) boş saxlayın
VITE_API_URL=

# Socket.io server URL (proxy ilə eyni)
VITE_SOCKET_URL=

# Production üçün nümunə:
# VITE_API_URL=https://api.luxdrive.az
# VITE_SOCKET_URL=https://api.luxdrive.az
