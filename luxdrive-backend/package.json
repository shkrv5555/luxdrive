{
  "name": "luxdrive-backend",
  "version": "1.0.0",
  "description": "Premium avtomobil icarəsi platforması üçün backend API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "psql -d luxdrive -f database/schema.sql",
    "db:migrate": "node database/migrate.js",
    "gen:secret": "node -e \"console.log(require('crypto').randomBytes(64).toString('hex'))\"",
    "test": "jest --runInBand"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "sharp": "^0.33.4",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "keywords": ["rent-a-car", "luxdrive", "api", "node", "express"],
  "author": "LuxDrive Team",
  "license": "MIT"
}
