# ════════════════════════════════════════════════════════════
# LuxDrive Backend — Mühit Dəyişənləri Şablonu
# Bu faylı kopyalayıb `.env` adı ilə saxlayın və real dəyərlərlə doldurun.
# .env FAYLINI HEÇ VAXT GIT-Ə ƏLAVƏ ETMƏYİN!
# ════════════════════════════════════════════════════════════

# Server konfiqurasiyası
NODE_ENV=development
PORT=5000

# PostgreSQL bağlantısı
DB_HOST=localhost
DB_PORT=5432
DB_NAME=luxdrive
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
# Alternativ: tam bağlantı URL-i (DB_* dəyişənlərini override edir)
# DATABASE_URL=postgresql://user:pass@host:5432/luxdrive

# JWT Açarları (KRİTİK — production-da uzun və təsadüfi olmalıdır!)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_me_to_another_different_random_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Admin başlanğıc kimlik məlumatları (server ilk işə düşəndə seed-də istifadə olunur)
ADMIN_EMAIL=admin@luxdrive.az
ADMIN_PASSWORD=Admin2024!

# CORS — icazə verilən frontend URL-ləri (vergüllə ayırın)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Fayl yükləmə
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Email (gələcək üçün — şifrə bərpası, doğrulama)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@luxdrive.az
